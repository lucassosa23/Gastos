# ============================================================================
# Gastitos - Variables de entorno
# Copiar este archivo a .env y rellenar con valores reales.
# El archivo .env NO se versiona (está en .gitignore).
# ============================================================================

# Clave secreta de Django. Generar con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-50-char-random-string

# Modo debug. Usar "True" SOLO en desarrollo local. NUNCA en producción.
DJANGO_DEBUG=True

# Hosts permitidos, separados por coma. En desarrollo: "localhost,127.0.0.1"
# En producción: el dominio público (ej: "gastitos.tudominio.com")
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
